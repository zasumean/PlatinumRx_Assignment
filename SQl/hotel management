**Query #1**

    -- 1st
    SELECT u.user_id, b.room_no
    FROM users u
    JOIN bookings b 
        ON u.user_id = b.user_id
    WHERE b.booking_date = (
        SELECT MAX(b2.booking_date)
        FROM bookings b2
        WHERE b2.user_id = u.user_id
    );

