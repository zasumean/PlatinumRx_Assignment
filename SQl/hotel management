**Query #4**

    -- 4th
    
    SELECT 
        SUBSTR(bc.bill_date, 1, 7) AS month,
        bc.item_id,
        SUM(bc.item_quantity) AS total_qty
    FROM booking_commercials bc
    GROUP BY month, bc.item_id
    ORDER BY month, total_qty DESC;

