**Query #3**

    -- 3rd
    
    SELECT 
        bc.bill_id,
        SUM(i.item_rate * bc.item_quantity) AS bill_amount
    FROM booking_commercials bc
    JOIN items i 
        ON bc.item_id = i.item_id
    WHERE bc.bill_date LIKE '2021-10%'
    GROUP BY bc.bill_id
    HAVING bill_amount > 1000;

