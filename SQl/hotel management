**Query #2**

    -- 2nd
    SELECT 
        b.booking_id,
        SUM(i.item_rate * bc.item_quantity) AS total_bill
    FROM bookings b
    JOIN booking_commercials bc 
        ON b.booking_id = bc.booking_id
    JOIN items i 
        ON bc.item_id = i.item_id
    WHERE b.booking_date LIKE '2021-11%'
    GROUP BY b.booking_id;

