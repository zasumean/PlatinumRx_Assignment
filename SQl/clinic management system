**Query #5**

    -- 5th
    SELECT 
        c.state, 
        c.clinic_name, 
        SUM(s.amount) AS revenue
    FROM clinic_sales s
    JOIN clinics c ON s.cid = c.cid
    GROUP BY c.state, c.clinic_name
    ORDER BY c.state, revenue ASC;

